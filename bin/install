#!/usr/bin/env bash
# bin/install — super-omni one-line bootstrap installer
#
# Designed to be piped from the internet:
#   curl -fsSL https://raw.githubusercontent.com/Wilder1222/super-omni/main/bin/install | bash
#   curl -fsSL https://raw.githubusercontent.com/Wilder1222/super-omni/main/bin/install | bash -s -- --only claude
#
# Or run locally:
#   bin/install [--only <platform>] [--skip <platform>] [--dry-run]

set -e

REPO_URL="https://github.com/Wilder1222/super-omni.git"
INSTALL_DIR="${HOME}/.claude/skills/super-omni"
VERSION="0.3.0"

# Pass through any arguments to the setup script
SETUP_ARGS=("$@")

echo ""
echo "╔══════════════════════════════════════════╗"
echo "║         super-omni  v${VERSION}               ║"
echo "║   One-line installer                     ║"
echo "╚══════════════════════════════════════════╝"
echo ""

# ── Check if already installed ────────────────────────────────────────────────
if [ -d "${INSTALL_DIR}/.git" ]; then
  echo "→ super-omni already installed at ${INSTALL_DIR}"
  echo "→ Pulling latest version..."
  git -C "${INSTALL_DIR}" pull --ff-only 2>/dev/null || {
    echo "  ⚠ Could not pull latest — run: git -C ${INSTALL_DIR} pull"
  }
  echo "  ✓ Updated to latest"
  echo ""
  echo "→ Re-running setup..."
  bash "${INSTALL_DIR}/setup" "${SETUP_ARGS[@]}"
  exit 0
fi

# ── Check dependencies ────────────────────────────────────────────────────────
if ! command -v git >/dev/null 2>&1; then
  echo "ERROR: git is required but not found. Please install git and try again." >&2
  exit 1
fi

# ── Clone the repository ──────────────────────────────────────────────────────
echo "→ Cloning super-omni into ${INSTALL_DIR}..."
mkdir -p "$(dirname "${INSTALL_DIR}")"
git clone --depth=1 "${REPO_URL}" "${INSTALL_DIR}" 2>/dev/null || {
  echo "ERROR: Failed to clone ${REPO_URL}" >&2
  echo "Try manually: git clone ${REPO_URL} ${INSTALL_DIR}" >&2
  exit 1
}
echo "  ✓ Cloned successfully"
echo ""

# ── Run setup ────────────────────────────────────────────────────────────────
echo "→ Running setup..."
bash "${INSTALL_DIR}/setup" "${SETUP_ARGS[@]}"
