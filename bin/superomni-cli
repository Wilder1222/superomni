#!/usr/bin/env node
// bin/superomni-cli — cross-platform CLI entry point

'use strict';

const { spawnSync } = require('child_process');
const fs = require('fs');
const path = require('path');

function toWslPath(p) {
  const m = p.match(/^([A-Za-z]):\\(.*)$/);
  if (!m) return p;
  return `/mnt/${m[1].toLowerCase()}/${m[2].replace(/\\/g, '/')}`;
}

function toMsysPath(p) {
  const m = p.match(/^([A-Za-z]):\\(.*)$/);
  if (!m) return p;
  return `/${m[1].toLowerCase()}/${m[2].replace(/\\/g, '/')}`;
}

function setupPathCandidates(setupScript) {
  const out = [setupScript];
  if (process.platform === 'win32') {
    out.push(toWslPath(setupScript));
    out.push(toMsysPath(setupScript));
  }
  return [...new Set(out)];
}

function runNpm(args) {
  const npmCmd = process.platform === 'win32' ? 'npm.cmd' : 'npm';
  return spawnSync(npmCmd, args, { stdio: 'inherit' });
}

const realPath = fs.realpathSync(process.argv[1]);
const scriptDir = path.dirname(realPath);
const packageRoot = path.resolve(scriptDir, '..');
const setupScript = path.join(packageRoot, 'setup');
const pkgPath = path.join(packageRoot, 'package.json');
const currentVersion = fs.existsSync(pkgPath)
  ? JSON.parse(fs.readFileSync(pkgPath, 'utf8')).version
  : 'unknown';

if (!fs.existsSync(setupScript)) {
  console.error(`ERROR: Cannot find setup script at ${setupScript}`);
  process.exit(1);
}

const command = process.argv[2] || '';

if (command === 'upgrade') {
  console.log('superomni upgrade — checking for updates...');
  console.log(`Current version: ${currentVersion}`);
  const result = runNpm(['install', '-g', 'github:Wilder1222/superomni']);
  process.exit(result.status || 0);
}

if (command === 'version' || command === '--version' || command === '-v') {
  console.log(`superomni ${currentVersion}`);
  process.exit(0);
}

if (command === 'help' || command === '--help' || command === '-h') {
  console.log('superomni — AI coding skill framework');
  console.log('');
  console.log('Usage:');
  console.log('  superomni [setup options]  Run setup/install for your platform');
  console.log('  superomni upgrade          Upgrade to the latest version');
  console.log('  superomni version          Print installed version');
  console.log('  superomni help             Show this help');
  process.exit(0);
}

const env = { ...process.env };
const initCwd = process.env.INIT_CWD;
if (
  !env.SUPEROMNI_TARGET_DIR &&
  process.env.npm_config_global !== 'true' &&
  initCwd &&
  initCwd !== packageRoot &&
  !initCwd.includes(`${path.sep}node_modules${path.sep}`)
) {
  env.SUPEROMNI_TARGET_DIR = initCwd;
}

const setupArgs = process.argv.slice(2);
const candidates = setupPathCandidates(setupScript);
let lastResult = null;
for (const candidate of candidates) {
  const result = spawnSync('bash', [candidate, ...setupArgs], {
    stdio: 'inherit',
    cwd: packageRoot,
    env,
  });
  if (!result.error && result.status === 0) {
    process.exit(0);
  }
  lastResult = result;
}

console.error('superomni cli: failed to run setup via bash.');
console.error(`superomni cli: attempted setup paths: ${candidates.join(', ')}`);
if (lastResult && lastResult.error) {
  console.error(`superomni cli: ${lastResult.error.message}`);
}
process.exit((lastResult && lastResult.status) || 1);

