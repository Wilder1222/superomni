#!/usr/bin/env node
'use strict';

const { spawnSync } = require('child_process');
const fs = require('fs');
const path = require('path');

const packageRoot = path.resolve(__dirname, '..');
const pkgPath = path.join(packageRoot, 'package.json');
const currentVersion = fs.existsSync(pkgPath)
    ? JSON.parse(fs.readFileSync(pkgPath, 'utf8')).version
    : 'unknown';

const args = process.argv.slice(2);
const firstArg = args[0] || '';

if (firstArg === 'upgrade') {
    console.log('superomni upgrade — reinstalling latest...');
    const npmCmd = process.platform === 'win32' ? 'npm.cmd' : 'npm';
    const r = spawnSync(npmCmd, ['install', '-g', 'github:Wilder1222/superomni'], { stdio: 'inherit' });
    process.exit(r.status || 0);
}

if (firstArg === 'version' || firstArg === '--version' || firstArg === '-v') {
    console.log('superomni ' + currentVersion);
    process.exit(0);
}

if (firstArg === 'help' || firstArg === '--help' || firstArg === '-h') {
    console.log('superomni ' + currentVersion + ' — AI coding skill framework\n');
    console.log('Usage:');
    console.log('  npx github:Wilder1222/superomni                 Install into current project');
    console.log('  npx github:Wilder1222/superomni --only claude   Claude Code only');
    console.log('  npx github:Wilder1222/superomni --only codex    Codex CLI only');
    console.log('  npx github:Wilder1222/superomni --only copilot  GitHub Copilot only');
    console.log('  npx github:Wilder1222/superomni --force         Force reinstall');
    console.log('  npx github:Wilder1222/superomni --dry-run       Preview changes');
    console.log('  npx github:Wilder1222/superomni --verbose       Detailed output');
    console.log('  superomni upgrade                               Upgrade to latest');
    console.log('\nPlatforms: claude, codex, gemini, copilot');
    process.exit(0);
}

const opts = { skip: [] };
for (let i = 0; i < args.length; i++) {
    const a = args[i];
    if (a === '--only')         { opts.only = args[++i]; }
    else if (a === '--skip')    { opts.skip.push(args[++i]); }
    else if (a === '--dry-run') { opts.dryRun = true; }
    else if (a === '--force')   { opts.force = true; }
    else if (a === '--verbose') { opts.verbose = true; }
}

const isGlobal = process.env.npm_config_global === 'true';
if (!isGlobal) {
    opts.targetDir = process.cwd();
}

const { run } = require('../lib/setup');
run(opts);
