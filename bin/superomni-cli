#!/usr/bin/env node
// bin/superomni-cli — CLI entry point for superomni
//
// When invoked via `npx github:Wilder1222/superomni`, runs in the user's
// current working directory and installs the skill framework there.
//
// Usage:
//   npx github:Wilder1222/superomni              # Install in current project
//   npx github:Wilder1222/superomni --only claude
//   npx github:Wilder1222/superomni --dry-run

'use strict';

const { spawnSync } = require('child_process');
const fs = require('fs');
const path = require('path');

const realPath = fs.realpathSync(process.argv[1]);
const scriptDir = path.dirname(realPath);
const packageRoot = path.resolve(scriptDir, '..');
const setupJs = path.join(packageRoot, 'lib', 'setup.js');
const pkgPath = path.join(packageRoot, 'package.json');
const currentVersion = fs.existsSync(pkgPath)
    ? JSON.parse(fs.readFileSync(pkgPath, 'utf8')).version
    : 'unknown';

const command = process.argv[2] || '';

if (command === 'upgrade') {
    console.log('superomni upgrade — reinstalling latest version...');
    const npmCmd = process.platform === 'win32' ? 'npm.cmd' : 'npm';
    const result = spawnSync(npmCmd, ['install', '-g', 'github:Wilder1222/superomni'], {
        stdio: 'inherit',
    });
    process.exit(result.status || 0);
}

if (command === 'version' || command === '--version' || command === '-v') {
    console.log(`superomni ${currentVersion}`);
    process.exit(0);
}

if (command === 'help' || command === '--help' || command === '-h') {
    console.log(`superomni ${currentVersion} — AI coding skill framework`);
    console.log('');
    console.log('Usage:');
    console.log('  npx superomni                    Install into current project');
    console.log('  npx superomni --only <platform>  Install for one platform only');
    console.log('  npx superomni --skip <platform>  Skip a specific platform');
    console.log('  npx superomni --dry-run          Preview without making changes');
    console.log('  npx superomni --verbose          Show detailed output');
    console.log('  npx superomni upgrade            Upgrade to latest version');
    console.log('  npx superomni version            Print version');
    console.log('');
    console.log('Platforms: claude, codex, gemini, copilot');
    process.exit(0);
}

// ── Locate setup script ───────────────────────────────────────────────────────

if (!fs.existsSync(setupJs)) {
    process.stderr.write(
        `superomni: setup script not found at ${setupJs}\n` +
        `superomni: package installation may be incomplete.\n`
    );
    process.exit(1);
}

// ── Determine target directory ────────────────────────────────────────────────
// process.cwd() is always the user's project directory when running via npx.

const env = Object.assign({}, process.env);

const isGlobalInstall = process.env.npm_config_global === 'true';

if (!isGlobalInstall && !env.SUPEROMNI_TARGET_DIR) {
    // npx run: install into the user's current working directory
    env.SUPEROMNI_TARGET_DIR = process.cwd();
}

// ── Run setup.js (pure Node.js) ───────────────────────────────────────────────

const setupArgs = process.argv.slice(2); // pass through any extra flags
const result = spawnSync(process.execPath, [setupJs, ...setupArgs], {
    cwd: packageRoot,
    env,
    stdio: 'inherit',
});

process.exit(result.status || 0);

