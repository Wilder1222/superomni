{
    "name": "superomni",
    "version": "0.5.7",
    "description": "superomni — A fused AI coding skill framework combining methodology-driven practices with engineering completeness. Plan Lean, Execute Complete.",
    "license": "MIT",
    "author": "Wilder1222",
    "keywords": [
        "claude-code",
        "ai-skills",
        "coding-assistant",
        "superpowers",
        "developer-productivity",
        "agents",
        "codex",
        "gemini",
        "github-copilot",
        "claude-skill",
        "npx"
    ],
    "bin": {
        "superomni": "./bin/superomni-cli"
    },
    "scripts": {
        "gen-skills": "node lib/gen-skill-docs.js",
        "gen-skills:bash": "bash lib/gen-skill-docs.sh",
        "gen-skills:ps": "pwsh -NoProfile -ExecutionPolicy Bypass -File lib/gen-skill-docs.ps1",
        "check:skill-docs": "node lib/check-skill-docs.js",
        "check:workflow-contract": "node lib/check-workflow-contract.js",
        "score:workflow": "node lib/score-workflow.js",
        "verify:skill-docs": "npm run gen-skills && npm run check:skill-docs",
        "ensure:lf": "node lib/ensure-setup-lf.js",
        "test": "bash lib/validate-skills.sh",
        "setup": "node lib/setup.js"
    },
    "files": [
        ".claude-plugin/",
        "agents/",
        "bin/",
        "commands/",
        "docs/",
        "hooks/",
        "lib/",
        "skills/",
        "setup",
        "CLAUDE.md",
        "ETHOS.md",
        "LICENSE",
        "claude-skill.json",
        "INSTALL_ARCHITECTURE.md"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Wilder1222/superomni.git"
    },
    "homepage": "https://github.com/Wilder1222/superomni#readme",
    "bugs": {
        "url": "https://github.com/Wilder1222/superomni/issues"
    }
}