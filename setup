#!/usr/bin/env bash
# super-omni setup script
# Installs the skill framework for Claude Code, Cursor, Codex CLI, Gemini CLI,
# OpenCode, VS Code (Cline/Continue.dev/Copilot), and JetBrains AI Assistant.

set -e

VERSION="0.3.0"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OMNI_STATE_DIR="${HOME}/.omni-skills"

# ── Platform detection ────────────────────────────────────────────────────────
IS_WSL=false
IS_MACOS=false
IS_LINUX=false

detect_platform() {
  case "$(uname -s)" in
    Darwin)  IS_MACOS=true ;;
    Linux)
      IS_LINUX=true
      if grep -qiE '(microsoft|wsl)' /proc/version 2>/dev/null; then
        IS_WSL=true
      fi
      ;;
  esac
}

# ── Help ──────────────────────────────────────────────────────────────────────
show_help() {
  cat <<HELP
super-omni v${VERSION} — Multi-platform AI skill framework installer

Usage: ./setup [OPTIONS]

Options:
  --help, -h        Show this help message
  --only <platform> Install for a single platform only
                    (claude, cursor, codex, gemini, opencode, vscode, jetbrains)
  --skip <platform> Skip a specific platform (repeatable)
  --dry-run         Show what would be done without making changes
  --verbose         Show detailed output

Supported platforms:
  claude     Claude Code       (~/.claude/skills/)
  cursor     Cursor            (~/.cursor/skills/)
  codex      Codex CLI         (~/.agents/skills/)
  gemini     Gemini CLI        (~/.gemini/skills/)
  opencode   OpenCode          (~/.opencode/skills/)
  vscode     VS Code (Cline/Continue.dev/Copilot) (~/.vscode-super-omni/)
  jetbrains  JetBrains AI Assistant (~/.jetbrains/super-omni/)

Examples:
  ./setup                     # Auto-detect and install all
  ./setup --only claude       # Install for Claude Code only
  ./setup --only vscode       # Install for VS Code only
  ./setup --skip gemini       # Install for all except Gemini
  ./setup --dry-run           # Preview what would happen
HELP
  exit 0
}

# ── CLI argument parsing ──────────────────────────────────────────────────────
ONLY_PLATFORM=""
SKIP_PLATFORMS=""
DRY_RUN=false
VERBOSE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)   show_help ;;
    --only)      ONLY_PLATFORM="$2"; shift 2 ;;
    --skip)      SKIP_PLATFORMS="${SKIP_PLATFORMS} $2"; shift 2 ;;
    --dry-run)   DRY_RUN=true; shift ;;
    --verbose)   VERBOSE=true; shift ;;
    *)           echo "Unknown option: $1 (try --help)"; exit 1 ;;
  esac
done

# ── Helpers ───────────────────────────────────────────────────────────────────
INSTALLED_PLATFORMS=""

# link_skills <skills_dir> <platform_label> <platform_key>
#   Creates <skills_dir>/super-omni as a symlink to SCRIPT_DIR.
#   Idempotent: re-creates stale symlinks, skips real directories.
link_skills() {
  local skills_dir="$1"
  local label="$2"
  local key="$3"
  local target="${skills_dir}/super-omni"

  if $DRY_RUN; then
    echo "  [dry-run] Would link ${SCRIPT_DIR} → ${target}"
    INSTALLED_PLATFORMS="${INSTALLED_PLATFORMS} ${key}"
    return
  fi

  mkdir -p "${skills_dir}"

  # Remove existing symlink so we can refresh it
  if [ -L "${target}" ]; then
    rm "${target}"
  fi

  if [ -d "${target}" ]; then
    echo "  ⚠ ${target} already exists (not a symlink). Skipping."
    return
  fi

  ln -s "${SCRIPT_DIR}" "${target}"
  echo "  ✓ ${label}: linked → ${target}"
  INSTALLED_PLATFORMS="${INSTALLED_PLATFORMS} ${key}"
}

# install_claude_commands
#   Symlinks each commands/*.md file into ~/.claude/commands/ so they become
#   native Claude Code slash commands (e.g. /brainstorm, /plugin, etc.).
#   Idempotent: refreshes stale symlinks, skips real files owned by others.
install_claude_commands() {
  local cmds_src="${SCRIPT_DIR}/commands"
  local cmds_dst="${HOME}/.claude/commands"

  if $DRY_RUN; then
    echo "  [dry-run] Would symlink commands/*.md → ${cmds_dst}/"
    return
  fi

  mkdir -p "${cmds_dst}"

  local count=0
  for cmd_file in "${cmds_src}"/*.md; do
    [ -f "${cmd_file}" ] || continue
    local cmd_name
    cmd_name="$(basename "${cmd_file}")"
    local target="${cmds_dst}/${cmd_name}"

    # Refresh stale symlinks
    if [ -L "${target}" ]; then
      rm "${target}"
    fi

    # Skip real (non-symlink) files we didn't create
    if [ -f "${target}" ]; then
      echo "  ⚠ ${target} already exists and is not managed by super-omni. Skipping to preserve user file."
      continue
    fi

    ln -s "${cmd_file}" "${target}"
    count=$((count + 1))
  done

  echo "  ✓ Claude Code commands linked (${count} commands) → ${cmds_dst}/"
}

# has_cli <command>
#   Returns 0 if the command exists on PATH.
has_cli() {
  command -v "$1" >/dev/null 2>&1
}

# should_install <platform_key>
#   Returns 0 if we should install for the given platform.
should_install() {
  local key="$1"
  # --only mode: only install the specified platform
  if [ -n "${ONLY_PLATFORM}" ]; then
    [ "${ONLY_PLATFORM}" = "${key}" ] && return 0 || return 1
  fi
  # --skip mode: skip the specified platforms
  case "${SKIP_PLATFORMS}" in
    *" ${key}"*) return 1 ;;
  esac
  return 0
}

# ── Banner ────────────────────────────────────────────────────────────────────
echo ""
echo "╔══════════════════════════════════════════╗"
echo "║         super-omni  v${VERSION}               ║"
echo "║   Plan Lean, Execute Complete            ║"
echo "╚══════════════════════════════════════════╝"
echo ""

detect_platform

if $IS_WSL; then
  echo "  ℹ Windows/WSL detected"
elif $IS_MACOS; then
  echo "  ℹ macOS detected"
elif $IS_LINUX; then
  echo "  ℹ Linux detected"
fi
if $DRY_RUN; then
  echo "  ℹ Dry-run mode — no changes will be made"
fi
echo ""

# ── 1. Create state directories ──────────────────────────────────────────────
echo "→ Creating state directories..."
if ! $DRY_RUN; then
  mkdir -p "${OMNI_STATE_DIR}/sessions"
  mkdir -p "${OMNI_STATE_DIR}/analytics"
  mkdir -p "${OMNI_STATE_DIR}/projects"
fi
echo "  ✓ ${OMNI_STATE_DIR}"

# ── 2. Build skill docs from templates ────────────────────────────────────────
echo "→ Building skill docs from templates..."
if ! $DRY_RUN; then
  bash "${SCRIPT_DIR}/lib/gen-skill-docs.sh"
fi
echo "  ✓ Skill docs generated"

# ── 3. Detect platforms & install skills ──────────────────────────────────────
echo "→ Detecting AI platforms..."

# ── 3a. Claude Code (primary) ────────────────────────────────────────────────
CLAUDE_SKILLS_DIR="${HOME}/.claude/skills"
if should_install "claude"; then
  if has_cli claude || [ -d "${HOME}/.claude" ]; then
    echo "  ● Claude Code detected"
    link_skills "${CLAUDE_SKILLS_DIR}" "Claude Code" "claude"
  elif [ -n "${ONLY_PLATFORM}" ]; then
    echo "  ● Claude Code (forced via --only)"
    link_skills "${CLAUDE_SKILLS_DIR}" "Claude Code" "claude"
  else
    # Always install for Claude as primary even if CLI not found
    echo "  ● Claude Code (primary — always installed)"
    link_skills "${CLAUDE_SKILLS_DIR}" "Claude Code" "claude"
  fi
  # Install slash commands so /brainstorm, /plugin, etc. are available in Claude Code
  install_claude_commands
fi

# ── 3b. Cursor ────────────────────────────────────────────────────────────────
CURSOR_SKILLS_DIR="${HOME}/.cursor/skills"
if should_install "cursor"; then
  if has_cli cursor || [ -d "${HOME}/.cursor" ]; then
    echo "  ● Cursor detected"
    link_skills "${CURSOR_SKILLS_DIR}" "Cursor" "cursor"
  elif [ -n "${ONLY_PLATFORM}" ] && [ "${ONLY_PLATFORM}" = "cursor" ]; then
    echo "  ● Cursor (forced via --only)"
    link_skills "${CURSOR_SKILLS_DIR}" "Cursor" "cursor"
  else
    $VERBOSE && echo "  ○ Cursor not detected (skipped)" || true
  fi
fi

# ── 3c. Codex CLI (OpenAI) ───────────────────────────────────────────────────
CODEX_SKILLS_DIR="${HOME}/.agents/skills"
if should_install "codex"; then
  if has_cli codex || [ -d "${HOME}/.agents" ]; then
    echo "  ● Codex CLI detected"
    link_skills "${CODEX_SKILLS_DIR}" "Codex CLI" "codex"
  elif [ -n "${ONLY_PLATFORM}" ] && [ "${ONLY_PLATFORM}" = "codex" ]; then
    echo "  ● Codex CLI (forced via --only)"
    link_skills "${CODEX_SKILLS_DIR}" "Codex CLI" "codex"
  else
    $VERBOSE && echo "  ○ Codex CLI not detected (skipped)" || true
  fi
fi

# ── 3d. Gemini CLI ───────────────────────────────────────────────────────────
GEMINI_SKILLS_DIR="${HOME}/.gemini/skills"
if should_install "gemini"; then
  if has_cli gemini || [ -d "${HOME}/.gemini" ]; then
    echo "  ● Gemini CLI detected"
    link_skills "${GEMINI_SKILLS_DIR}" "Gemini CLI" "gemini"
  elif [ -n "${ONLY_PLATFORM}" ] && [ "${ONLY_PLATFORM}" = "gemini" ]; then
    echo "  ● Gemini CLI (forced via --only)"
    link_skills "${GEMINI_SKILLS_DIR}" "Gemini CLI" "gemini"
  else
    $VERBOSE && echo "  ○ Gemini CLI not detected (skipped)" || true
  fi
fi

# ── 3e. OpenCode ─────────────────────────────────────────────────────────────
OPENCODE_SKILLS_DIR="${HOME}/.opencode/skills"
if should_install "opencode"; then
  if has_cli opencode || [ -d "${HOME}/.opencode" ]; then
    echo "  ● OpenCode detected"
    link_skills "${OPENCODE_SKILLS_DIR}" "OpenCode" "opencode"
  elif [ -n "${ONLY_PLATFORM}" ] && [ "${ONLY_PLATFORM}" = "opencode" ]; then
    echo "  ● OpenCode (forced via --only)"
    link_skills "${OPENCODE_SKILLS_DIR}" "OpenCode" "opencode"
  else
    $VERBOSE && echo "  ○ OpenCode not detected (skipped)" || true
  fi
fi

# ── 3f. VS Code (Cline / Continue.dev / GitHub Copilot) ──────────────────────
# Writes skills into ~/.vscode-super-omni/ and generates per-extension configs.
VSCODE_OMNI_DIR="${HOME}/.vscode-super-omni"
install_vscode() {
  local label="$1"
  local key="$2"

  if $DRY_RUN; then
    echo "  [dry-run] Would set up VS Code support at ${VSCODE_OMNI_DIR}"
    INSTALLED_PLATFORMS="${INSTALLED_PLATFORMS} ${key}"
    return
  fi

  mkdir -p "${VSCODE_OMNI_DIR}"

  # Symlink the full skill set so VS Code extensions can find it
  if [ -L "${VSCODE_OMNI_DIR}/skills" ]; then
    rm "${VSCODE_OMNI_DIR}/skills"
  fi
  if [ ! -d "${VSCODE_OMNI_DIR}/skills" ]; then
    ln -s "${SCRIPT_DIR}/skills" "${VSCODE_OMNI_DIR}/skills"
  fi

  # ── Cline (rooveterinaryinc.roo-cline / saoudrizwan.claude-dev) ───────────
  # Cline reads custom instructions from .clinerules in the project root or
  # from a global file. We write a global pointer.
  CLINE_RULES_DIR="${HOME}/.cline"
  mkdir -p "${CLINE_RULES_DIR}"
  cat > "${CLINE_RULES_DIR}/super-omni.md" <<CLINE_EOF
# super-omni Skills

Skills directory: ${VSCODE_OMNI_DIR}/skills
Agent library:    ${SCRIPT_DIR}/agents

Load \`${VSCODE_OMNI_DIR}/skills/using-skills/SKILL.md\` at session start.
See \`${SCRIPT_DIR}/agents/\` for specialized agents.
CLINE_EOF

  # ── Continue.dev ──────────────────────────────────────────────────────────
  CONTINUE_CONFIG_DIR="${HOME}/.continue"
  mkdir -p "${CONTINUE_CONFIG_DIR}"
  # Only add our context provider if not already present
  if [ -f "${CONTINUE_CONFIG_DIR}/config.json" ]; then
    if ! grep -q "super-omni" "${CONTINUE_CONFIG_DIR}/config.json" 2>/dev/null; then
      echo "  ℹ Continue.dev config exists — add the following context path manually:"
      echo "      ${VSCODE_OMNI_DIR}/skills"
    fi
  else
    cat > "${CONTINUE_CONFIG_DIR}/config.json" <<CONTINUE_EOF
{
  "contextProviders": [
    {
      "name": "file",
      "params": {
        "nRetrieve": 10,
        "nFinal": 5
      }
    }
  ],
  "customCommands": [
    {
      "name": "super-omni",
      "description": "Load super-omni skills",
      "prompt": "Load and follow the skills in ${VSCODE_OMNI_DIR}/skills/using-skills/SKILL.md. Then ask me what I need help with."
    }
  ],
  "models": []
}
CONTINUE_EOF
  fi

  echo "  ✓ ${label}: configured → ${VSCODE_OMNI_DIR}"
  INSTALLED_PLATFORMS="${INSTALLED_PLATFORMS} ${key}"
}

if should_install "vscode"; then
  # Detect VS Code or its extensions
  if has_cli code || [ -d "${HOME}/.vscode" ] || [ -d "${HOME}/.vscode-server" ]; then
    echo "  ● VS Code detected"
    install_vscode "VS Code (Cline/Continue.dev)" "vscode"
  elif [ -n "${ONLY_PLATFORM}" ] && [ "${ONLY_PLATFORM}" = "vscode" ]; then
    echo "  ● VS Code (forced via --only)"
    install_vscode "VS Code (Cline/Continue.dev)" "vscode"
  else
    $VERBOSE && echo "  ○ VS Code not detected (skipped)" || true
  fi
fi

# ── 3g. JetBrains AI Assistant ───────────────────────────────────────────────
JETBRAINS_OMNI_DIR="${HOME}/.jetbrains/super-omni"
install_jetbrains() {
  local label="$1"
  local key="$2"

  if $DRY_RUN; then
    echo "  [dry-run] Would set up JetBrains support at ${JETBRAINS_OMNI_DIR}"
    INSTALLED_PLATFORMS="${INSTALLED_PLATFORMS} ${key}"
    return
  fi

  mkdir -p "${JETBRAINS_OMNI_DIR}"

  # Symlink skills
  if [ -L "${JETBRAINS_OMNI_DIR}/skills" ]; then
    rm "${JETBRAINS_OMNI_DIR}/skills"
  fi
  if [ ! -d "${JETBRAINS_OMNI_DIR}/skills" ]; then
    ln -s "${SCRIPT_DIR}/skills" "${JETBRAINS_OMNI_DIR}/skills"
  fi

  # Write a prompt file for JetBrains AI Assistant custom prompts
  # (stored in ~/.config/JetBrains/<product>/ai-prompts/ or similar)
  # We write a portable README to guide manual setup.
  cat > "${JETBRAINS_OMNI_DIR}/SETUP.md" <<JB_EOF
# super-omni for JetBrains AI Assistant

## Setup Instructions

1. Open JetBrains IDE → Settings → Tools → AI Assistant → Prompts
2. Click "+" to add a new prompt
3. Name: "super-omni"
4. Content:
   \`\`\`
   You are augmented with the super-omni skill framework.
   Skills directory: ${JETBRAINS_OMNI_DIR}/skills
   Agent library:    ${SCRIPT_DIR}/agents

   Load and follow: ${JETBRAINS_OMNI_DIR}/skills/using-skills/SKILL.md
   \`\`\`

## Available Skills

Skills are located at: ${JETBRAINS_OMNI_DIR}/skills/

## Available Agents

Agents are located at: ${SCRIPT_DIR}/agents/
JB_EOF

  echo "  ✓ ${label}: configured → ${JETBRAINS_OMNI_DIR}"
  echo "  ℹ See ${JETBRAINS_OMNI_DIR}/SETUP.md for JetBrains AI Assistant configuration"
  INSTALLED_PLATFORMS="${INSTALLED_PLATFORMS} ${key}"
}

if should_install "jetbrains"; then
  # Detect JetBrains IDEs (IDEA, PyCharm, GoLand, WebStorm, etc.)
  # Use compgen to safely expand glob patterns; avoids iterating literal strings
  # when no matching directory exists.
  JB_DETECTED=false
  JB_GLOB_PATTERNS=(
    "${HOME}/.IntelliJIdea"
    "${HOME}/.PyCharm"
    "${HOME}/.GoLand"
    "${HOME}/.WebStorm"
    "${HOME}/.RubyMine"
    "${HOME}/.DataGrip"
    "${HOME}/.CLion"
    "${HOME}/.PhpStorm"
    "${HOME}/.Rider"
  )
  # Check fixed paths first
  for jb_fixed in "${HOME}/.idea" "${HOME}/Library/Application Support/JetBrains"; do
    if [ -d "${jb_fixed}" ]; then
      JB_DETECTED=true
      break
    fi
  done
  # Then check versioned dirs via glob expansion
  if ! $JB_DETECTED; then
    for jb_prefix in "${JB_GLOB_PATTERNS[@]}"; do
      # compgen -G returns exit code 1 if no matches — safe to ignore
      if compgen -G "${jb_prefix}*" > /dev/null 2>&1; then
        JB_DETECTED=true
        break
      fi
    done
  fi

  if $JB_DETECTED; then
    echo "  ● JetBrains IDE detected"
    install_jetbrains "JetBrains AI Assistant" "jetbrains"
  elif [ -n "${ONLY_PLATFORM}" ] && [ "${ONLY_PLATFORM}" = "jetbrains" ]; then
    echo "  ● JetBrains (forced via --only)"
    install_jetbrains "JetBrains AI Assistant" "jetbrains"
  else
    $VERBOSE && echo "  ○ JetBrains IDEs not detected (skipped)" || true
  fi
fi

# ── 4. Register hooks (Claude Code specific) ─────────────────────────────────
HOOKS_SOURCE="${SCRIPT_DIR}/hooks/hooks.json"
CLAUDE_HOOKS_DIR="${HOME}/.claude/hooks"

if should_install "claude"; then
  echo "→ Registering Claude Code hooks..."
  if ! $DRY_RUN; then
    mkdir -p "${CLAUDE_HOOKS_DIR}"
    if [ -f "${HOOKS_SOURCE}" ]; then
      cp "${HOOKS_SOURCE}" "${CLAUDE_HOOKS_DIR}/super-omni-hooks.json"
      echo "  ✓ Hooks registered"
    fi
  else
    echo "  [dry-run] Would copy hooks.json → ${CLAUDE_HOOKS_DIR}"
  fi
fi

# ── 5. Make bin scripts executable ────────────────────────────────────────────
echo "→ Setting executable permissions..."
if ! $DRY_RUN; then
  chmod +x "${SCRIPT_DIR}/bin/config" 2>/dev/null || true
  chmod +x "${SCRIPT_DIR}/bin/slug" 2>/dev/null || true
  chmod +x "${SCRIPT_DIR}/bin/analytics-log" 2>/dev/null || true
  chmod +x "${SCRIPT_DIR}/bin/agent-manager" 2>/dev/null || true
  chmod +x "${SCRIPT_DIR}/bin/skill-manager" 2>/dev/null || true
  chmod +x "${SCRIPT_DIR}/lib/gen-skill-docs.sh" 2>/dev/null || true
fi
echo "  ✓ Scripts made executable"

# ── 6. Initialize default config ─────────────────────────────────────────────
CONFIG_FILE="${OMNI_STATE_DIR}/config"
if ! $DRY_RUN; then
  if [ ! -f "${CONFIG_FILE}" ]; then
    cat > "${CONFIG_FILE}" << 'EOF'
proactive=true
telemetry=true
EOF
    echo "  ✓ Default config initialized (proactive=true, telemetry=true)"
  else
    echo "  ✓ Config already exists at ${CONFIG_FILE}"
  fi
else
  echo "  [dry-run] Would initialize config at ${CONFIG_FILE}"
fi

# ── 7. Summary ────────────────────────────────────────────────────────────────
echo ""
if [ -z "${INSTALLED_PLATFORMS}" ]; then
  echo "⚠ No platforms were installed. Use --only <platform> to force."
  exit 1
fi

# Count installed platforms
PLATFORM_COUNT=0
for _ in ${INSTALLED_PLATFORMS}; do
  PLATFORM_COUNT=$((PLATFORM_COUNT + 1))
done

echo "✅ super-omni v${VERSION} installed for ${PLATFORM_COUNT} platform(s)"
echo ""
echo "Installed platforms:"
for key in ${INSTALLED_PLATFORMS}; do
  case "${key}" in
    claude)    echo "  • Claude Code              → ~/.claude/skills/super-omni"
               echo "                               ~/.claude/commands/ (slash commands)" ;;
    cursor)    echo "  • Cursor                   → ~/.cursor/skills/super-omni" ;;
    codex)     echo "  • Codex CLI                → ~/.agents/skills/super-omni" ;;
    gemini)    echo "  • Gemini CLI               → ~/.gemini/skills/super-omni" ;;
    opencode)  echo "  • OpenCode                 → ~/.opencode/skills/super-omni" ;;
    vscode)    echo "  • VS Code (Cline/Continue) → ~/.vscode-super-omni/" ;;
    jetbrains) echo "  • JetBrains AI Assistant   → ~/.jetbrains/super-omni/" ;;
  esac
done

echo ""
echo "Next steps:"
echo "  1. Open a project in Claude Code"
echo "  2. All slash commands are immediately available:"
echo "     /supervibe  /brainstorm  /write-plan  /execute-plan"
echo "     /review  /ship  /retro  /investigate  /workflow"
echo "     /qa  /security  /plugin  /list-skills  /install-skill"
echo "     /list-agents  /install-agent  /create-agent"
echo "  3. Skills auto-activate via session hooks for other triggers"
echo ""
echo "Agent management:"
echo "  ${SCRIPT_DIR}/bin/agent-manager list           # list all agents"
echo "  ${SCRIPT_DIR}/bin/agent-manager install <url>  # install from URL"
echo "  ${SCRIPT_DIR}/bin/agent-manager create <name>  # create custom agent"
echo ""
echo "Skill marketplace:"
echo "  ${SCRIPT_DIR}/bin/skill-manager list           # list all skills"
echo "  ${SCRIPT_DIR}/bin/skill-manager install <src>  # install from URL/path"
echo "  ${SCRIPT_DIR}/bin/skill-manager remove <name>  # remove installed skill"
echo ""
echo "To disable auto-skill triggers:"
echo "  ${SCRIPT_DIR}/bin/config set proactive false"
echo ""
