#!/usr/bin/env bash
# superomni setup script
# Installs the skill framework for Claude Code, Codex CLI, Gemini CLI,
# and GitHub Copilot.

set -e

VERSION="0.4.1"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OMNI_STATE_DIR="${HOME}/.omni-skills"

# When set (e.g. by postinstall.js for npx runs), install into this directory
# instead of global platform directories.
TARGET_DIR="${SUPEROMNI_TARGET_DIR:-}"

# ── Platform detection ────────────────────────────────────────────────────────
IS_WSL=false
IS_MACOS=false
IS_LINUX=false

detect_platform() {
  case "$(uname -s)" in
    Darwin)  IS_MACOS=true ;;
    Linux)
      IS_LINUX=true
      if grep -qiE '(microsoft|wsl)' /proc/version 2>/dev/null; then
        IS_WSL=true
      fi
      ;;
  esac
}

# ── Help ──────────────────────────────────────────────────────────────────────
show_help() {
  cat <<HELP
superomni v${VERSION} — AI skill framework setup

Usage: setup [OPTIONS]

  This script is run automatically by:
    npm install -g superomni   (global install)
    npx superomni              (project-level install — installs into CWD)

  For Claude Code, install via the marketplace instead:
    /plugin marketplace add Wilder1222/superomni

Options:
  --help, -h        Show this help message
  --only <platform> Install for a single platform only
                    (claude, codex, gemini, copilot)
  --skip <platform> Skip a specific platform (repeatable)
  --dry-run         Show what would be done without making changes
  --verbose         Show detailed output

Supported platforms:
  claude   Claude Code        (~/.claude/skills/)
  codex    Codex CLI          (~/.agents/skills/ or <project>/AGENTS.md)
  gemini   Gemini CLI         (~/.gemini/skills/ or <project>/GEMINI.md)
  copilot  GitHub Copilot     (<project>/.github/copilot-instructions.md)

Examples:
  npm install -g superomni   # Global install — auto-detect platforms
  npx superomni              # Project install — writes config into CWD
  npx superomni --only codex
  npx superomni --skip gemini
HELP
  exit 0
}

# ── CLI argument parsing ──────────────────────────────────────────────────────
ONLY_PLATFORM=""
SKIP_PLATFORMS=""
DRY_RUN=false
VERBOSE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)   show_help ;;
    --only)      ONLY_PLATFORM="$2"; shift 2 ;;
    --skip)      SKIP_PLATFORMS="${SKIP_PLATFORMS} $2"; shift 2 ;;
    --dry-run)   DRY_RUN=true; shift ;;
    --verbose)   VERBOSE=true; shift ;;
    *)           echo "Unknown option: $1 (try --help)"; exit 1 ;;
  esac
done

# ── Helpers ───────────────────────────────────────────────────────────────────
INSTALLED_PLATFORMS=""

# link_skills <skills_dir> <platform_label> <platform_key>
#   Creates <skills_dir>/superomni as a symlink to SCRIPT_DIR.
#   Idempotent: re-creates stale symlinks, skips real directories.
link_skills() {
  local skills_dir="$1"
  local label="$2"
  local key="$3"
  local target="${skills_dir}/superomni"

  if $DRY_RUN; then
    echo "  [dry-run] Would link ${SCRIPT_DIR} → ${target}"
    INSTALLED_PLATFORMS="${INSTALLED_PLATFORMS} ${key}"
    return
  fi

  mkdir -p "${skills_dir}"

  # Remove existing symlink so we can refresh it
  if [ -L "${target}" ]; then
    rm "${target}"
  fi

  if [ -d "${target}" ]; then
    echo "  ⚠ ${target} already exists (not a symlink). Skipping."
    return
  fi

  ln -s "${SCRIPT_DIR}" "${target}"
  echo "  ✓ ${label}: linked → ${target}"
  INSTALLED_PLATFORMS="${INSTALLED_PLATFORMS} ${key}"
}

# install_claude_commands
#   Symlinks each commands/*.md file into ~/.claude/commands/ so they become
#   native Claude Code slash commands (e.g. /vibe, /brainstorm, etc.).
#   Idempotent: refreshes stale symlinks, skips real files owned by others.
install_claude_commands() {
  local cmds_src="${SCRIPT_DIR}/commands"
  local cmds_dst="${HOME}/.claude/commands"

  if $DRY_RUN; then
    echo "  [dry-run] Would symlink commands/*.md → ${cmds_dst}/"
    return
  fi

  mkdir -p "${cmds_dst}"

  local count=0
  for cmd_file in "${cmds_src}"/*.md; do
    [ -f "${cmd_file}" ] || continue
    local cmd_name
    cmd_name="$(basename "${cmd_file}")"
    local target="${cmds_dst}/${cmd_name}"

    # Refresh stale symlinks
    if [ -L "${target}" ]; then
      rm "${target}"
    fi

    # Skip real (non-symlink) files we didn't create
    if [ -f "${target}" ]; then
      echo "  ⚠ ${target} already exists and is not managed by superomni. Skipping to preserve user file."
      continue
    fi

    ln -s "${cmd_file}" "${target}"
    count=$((count + 1))
  done

  echo "  ✓ Claude Code commands linked (${count} commands) → ${cmds_dst}/"
}

# has_cli <command>
#   Returns 0 if the command exists on PATH.
has_cli() {
  command -v "$1" >/dev/null 2>&1
}

# should_install <platform_key>
#   Returns 0 if we should install for the given platform.
should_install() {
  local key="$1"
  # --only mode: only install the specified platform
  if [ -n "${ONLY_PLATFORM}" ]; then
    [ "${ONLY_PLATFORM}" = "${key}" ] && return 0 || return 1
  fi
  # --skip mode: skip the specified platforms
  case "${SKIP_PLATFORMS}" in
    *" ${key}"*) return 1 ;;
  esac
  return 0
}

# ── Banner ────────────────────────────────────────────────────────────────────
echo ""
echo "╔══════════════════════════════════════════╗"
echo "║         superomni  v${VERSION}               ║"
echo "║   Plan Lean, Execute Complete            ║"
echo "╚══════════════════════════════════════════╝"
echo ""

detect_platform

if $IS_WSL; then
  echo "  ℹ Windows/WSL detected"
elif $IS_MACOS; then
  echo "  ℹ macOS detected"
elif $IS_LINUX; then
  echo "  ℹ Linux detected"
fi
if $DRY_RUN; then
  echo "  ℹ Dry-run mode — no changes will be made"
fi
echo ""

# ── 1. Create state directories ──────────────────────────────────────────────
echo "→ Creating state directories..."
if ! $DRY_RUN; then
  mkdir -p "${OMNI_STATE_DIR}/sessions"
  mkdir -p "${OMNI_STATE_DIR}/analytics"
  mkdir -p "${OMNI_STATE_DIR}/projects"
fi
echo "  ✓ ${OMNI_STATE_DIR}"

# ── 2. Build skill docs from templates ────────────────────────────────────────
echo "→ Building skill docs from templates..."
if ! $DRY_RUN; then
  bash "${SCRIPT_DIR}/lib/gen-skill-docs.sh"
fi
echo "  ✓ Skill docs generated"

# ── 3. Detect platforms & install skills ──────────────────────────────────────
echo "→ Detecting AI platforms..."

# ── Helpers for local (project-level) installs ───────────────────────────────
# copy_skills_local <target_dir>
#   Copies the full skills/agents/commands tree into <target_dir>/.superomni/
#   so that the project directory is self-contained even after npx cleanup.
#   Idempotent: skips if .superomni/ already exists.
copy_skills_local() {
  local dest_dir="$1/.superomni"

  if $DRY_RUN; then
    echo "  [dry-run] Would copy skills → ${dest_dir}"
    return
  fi

  # Skip copy if already installed to avoid nested duplicates on repeated calls
  if [ -d "${dest_dir}/skills" ]; then
    return
  fi

  mkdir -p "${dest_dir}"
  cp -r "${SCRIPT_DIR}/skills"   "${dest_dir}/skills"
  cp -r "${SCRIPT_DIR}/agents"   "${dest_dir}/agents"
  cp -r "${SCRIPT_DIR}/commands" "${dest_dir}/commands"
  echo "  ✓ Skills copied → ${dest_dir}"
}

# write_local_config <file> <content>
#   Writes <file> only if it does not yet reference superomni.
write_local_config() {
  local file="$1"
  local content="$2"
  local dir
  dir="$(dirname "${file}")"

  if $DRY_RUN; then
    echo "  [dry-run] Would write ${file}"
    return
  fi

  mkdir -p "${dir}"
  if [ -f "${file}" ] && grep -q "superomni" "${file}" 2>/dev/null; then
    echo "  ✓ ${file} already references superomni (skipped)"
    return
  fi
  printf '%s\n' "${content}" >> "${file}"
  echo "  ✓ Written → ${file}"
}

# ── Shared skill snippet for local config files ───────────────────────────────
# Used by Codex (AGENTS.md), Gemini (GEMINI.md), and Copilot
# (.github/copilot-instructions.md) local installs.
LOCAL_SKILL_SNIPPET="# superomni Skills

You are augmented with the superomni AI coding skill framework.

Skills directory: .superomni/skills
Agent library:    .superomni/agents

Load and follow \`.superomni/skills/using-skills/SKILL.md\` at session start.
See \`.superomni/agents/\` for specialized agents."

# ── 3a. Claude Code (primary — always installed globally) ────────────────────
CLAUDE_SKILLS_DIR="${HOME}/.claude/skills"
if should_install "claude"; then
  echo "  ● Claude Code (primary — always installed)"
  link_skills "${CLAUDE_SKILLS_DIR}" "Claude Code" "claude"
  # Install slash commands so /vibe, /brainstorm, etc. are available in Claude Code
  install_claude_commands
fi

# ── 3b. Codex CLI (OpenAI) ───────────────────────────────────────────────────
if should_install "codex"; then
  if [ -n "${TARGET_DIR}" ]; then
    # ── Local / npx install: write AGENTS.md into project root ───────────────
    echo "  ● Codex CLI (local install → ${TARGET_DIR})"
    copy_skills_local "${TARGET_DIR}"
    write_local_config "${TARGET_DIR}/AGENTS.md" "${LOCAL_SKILL_SNIPPET}"
    INSTALLED_PLATFORMS="${INSTALLED_PLATFORMS} codex"
  else
    # ── Global install: symlink into ~/.agents/skills/ ────────────────────────
    CODEX_SKILLS_DIR="${HOME}/.agents/skills"
    if has_cli codex || [ -d "${HOME}/.agents" ]; then
      echo "  ● Codex CLI detected"
      link_skills "${CODEX_SKILLS_DIR}" "Codex CLI" "codex"
    elif [ -n "${ONLY_PLATFORM}" ] && [ "${ONLY_PLATFORM}" = "codex" ]; then
      echo "  ● Codex CLI (forced via --only)"
      link_skills "${CODEX_SKILLS_DIR}" "Codex CLI" "codex"
    else
      $VERBOSE && echo "  ○ Codex CLI not detected (skipped)" || true
    fi
  fi
fi

# ── 3c. Gemini CLI ───────────────────────────────────────────────────────────
if should_install "gemini"; then
  if [ -n "${TARGET_DIR}" ]; then
    # ── Local / npx install: write GEMINI.md into project root ───────────────
    echo "  ● Gemini CLI (local install → ${TARGET_DIR})"
    copy_skills_local "${TARGET_DIR}"
    write_local_config "${TARGET_DIR}/GEMINI.md" "${LOCAL_SKILL_SNIPPET}"
    INSTALLED_PLATFORMS="${INSTALLED_PLATFORMS} gemini"
  else
    # ── Global install: symlink into ~/.gemini/skills/ ────────────────────────
    GEMINI_SKILLS_DIR="${HOME}/.gemini/skills"
    if has_cli gemini || [ -d "${HOME}/.gemini" ]; then
      echo "  ● Gemini CLI detected"
      link_skills "${GEMINI_SKILLS_DIR}" "Gemini CLI" "gemini"
    elif [ -n "${ONLY_PLATFORM}" ] && [ "${ONLY_PLATFORM}" = "gemini" ]; then
      echo "  ● Gemini CLI (forced via --only)"
      link_skills "${GEMINI_SKILLS_DIR}" "Gemini CLI" "gemini"
    else
      $VERBOSE && echo "  ○ Gemini CLI not detected (skipped)" || true
    fi
  fi
fi

# ── 3d. GitHub Copilot ───────────────────────────────────────────────────────
# Copilot reads .github/copilot-instructions.md from the project root.
# This is always a per-project install (no meaningful global path).
if should_install "copilot"; then
  local_dir="${TARGET_DIR:-${PWD}}"
  COPILOT_INSTRUCTIONS="${local_dir}/.github/copilot-instructions.md"
  if has_cli gh || has_cli copilot || [ -d "${local_dir}/.github" ] || [ -n "${TARGET_DIR}" ]; then
    echo "  ● GitHub Copilot (local install → ${local_dir})"
    copy_skills_local "${local_dir}"
    write_local_config "${COPILOT_INSTRUCTIONS}" "${LOCAL_SKILL_SNIPPET}"
    INSTALLED_PLATFORMS="${INSTALLED_PLATFORMS} copilot"
  elif [ -n "${ONLY_PLATFORM}" ] && [ "${ONLY_PLATFORM}" = "copilot" ]; then
    echo "  ● GitHub Copilot (forced via --only)"
    copy_skills_local "${local_dir}"
    write_local_config "${COPILOT_INSTRUCTIONS}" "${LOCAL_SKILL_SNIPPET}"
    INSTALLED_PLATFORMS="${INSTALLED_PLATFORMS} copilot"
  else
    $VERBOSE && echo "  ○ GitHub Copilot not detected (skipped)" || true
  fi
fi

# ── 4. Register hooks (Claude Code specific) ─────────────────────────────────
HOOKS_SOURCE="${SCRIPT_DIR}/hooks/hooks.json"
CLAUDE_HOOKS_DIR="${HOME}/.claude/hooks"

if should_install "claude"; then
  echo "→ Registering Claude Code hooks..."
  if ! $DRY_RUN; then
    mkdir -p "${CLAUDE_HOOKS_DIR}"
    if [ -f "${HOOKS_SOURCE}" ]; then
      cp "${HOOKS_SOURCE}" "${CLAUDE_HOOKS_DIR}/superomni-hooks.json"
      echo "  ✓ Hooks registered"
    fi
  else
    echo "  [dry-run] Would copy hooks.json → ${CLAUDE_HOOKS_DIR}"
  fi
fi

# ── 5. Make bin scripts executable ────────────────────────────────────────────
echo "→ Setting executable permissions..."
if ! $DRY_RUN; then
  chmod +x "${SCRIPT_DIR}/bin/config" 2>/dev/null || true
  chmod +x "${SCRIPT_DIR}/bin/slug" 2>/dev/null || true
  chmod +x "${SCRIPT_DIR}/bin/analytics-log" 2>/dev/null || true
  chmod +x "${SCRIPT_DIR}/bin/agent-manager" 2>/dev/null || true
  chmod +x "${SCRIPT_DIR}/bin/skill-manager" 2>/dev/null || true
  chmod +x "${SCRIPT_DIR}/lib/gen-skill-docs.sh" 2>/dev/null || true
fi
echo "  ✓ Scripts made executable"

# ── 6. Initialize default config ─────────────────────────────────────────────
CONFIG_FILE="${OMNI_STATE_DIR}/config"
if ! $DRY_RUN; then
  if [ ! -f "${CONFIG_FILE}" ]; then
    cat > "${CONFIG_FILE}" << 'EOF'
proactive=true
telemetry=true
EOF
    echo "  ✓ Default config initialized (proactive=true, telemetry=true)"
  else
    echo "  ✓ Config already exists at ${CONFIG_FILE}"
  fi
else
  echo "  [dry-run] Would initialize config at ${CONFIG_FILE}"
fi

# ── 7. Summary ────────────────────────────────────────────────────────────────
echo ""
if [ -z "${INSTALLED_PLATFORMS}" ]; then
  echo "⚠ No platforms were installed. Use --only <platform> to force."
  exit 1
fi

# Count installed platforms
PLATFORM_COUNT=0
for _ in ${INSTALLED_PLATFORMS}; do
  PLATFORM_COUNT=$((PLATFORM_COUNT + 1))
done

echo "✅ superomni v${VERSION} installed for ${PLATFORM_COUNT} platform(s)"
echo ""
echo "Installed platforms:"
for key in ${INSTALLED_PLATFORMS}; do
  case "${key}" in
    claude)  echo "  • Claude Code      → ~/.claude/skills/superomni"
             echo "                       ~/.claude/commands/ (slash commands)" ;;
    codex)   if [ -n "${TARGET_DIR}" ]; then
               echo "  • Codex CLI        → ${TARGET_DIR}/AGENTS.md"
             else
               echo "  • Codex CLI        → ~/.agents/skills/superomni"
             fi ;;
    gemini)  if [ -n "${TARGET_DIR}" ]; then
               echo "  • Gemini CLI       → ${TARGET_DIR}/GEMINI.md"
             else
               echo "  • Gemini CLI       → ~/.gemini/skills/superomni"
             fi ;;
    copilot) echo "  • GitHub Copilot   → ${TARGET_DIR:-${PWD}}/.github/copilot-instructions.md" ;;
  esac
done

echo ""
echo "Next steps:"
if [ -n "${TARGET_DIR}" ]; then
  echo "  1. Commit the generated config files (.superomni/, AGENTS.md, GEMINI.md, etc.) or add them to .gitignore"
  echo "  2. Open your project in your AI CLI — skills activate automatically"
else
  echo "  1. Open your project in your AI CLI or IDE"
  echo "  2. Skills activate automatically via session hooks"
fi
echo "  For Claude Code users: install via the marketplace instead:"
echo "    /plugin marketplace add Wilder1222/superomni"
echo ""
echo "To disable auto-skill triggers:"
echo "  ${SCRIPT_DIR}/bin/config set proactive false"
echo ""
